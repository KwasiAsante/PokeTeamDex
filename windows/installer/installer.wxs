<Wix xmlns="http://wixtoolset.org/schemas/v4/wxs"
     xmlns:ui="http://wixtoolset.org/schemas/v4/wxs/ui">

  <Package Name="PokeTeamDex"
           Manufacturer="Asante"
           Version="$(Version)"
           UpgradeCode="E3A7F1B2-4C5D-4E6F-8A9B-0C1D2E3F4A5B"
           Scope="perMachine">

    <!--
      Version detection using the shared UpgradeCode.
        UPGRADE_FOUND      — older version installed (we are newer)
        SAME_VERSION_FOUND — identical version already installed
        DOWNGRADE_FOUND    — newer version installed (we are older)
    -->
    <Upgrade Id="E3A7F1B2-4C5D-4E6F-8A9B-0C1D2E3F4A5B">
      <UpgradeVersion
        Minimum="0.0.0"    IncludeMinimum="yes"
        Maximum="$(Version)" IncludeMaximum="no"
        Property="UPGRADE_FOUND"
        MigrateFeatures="yes" />
      <UpgradeVersion
        Minimum="$(Version)" IncludeMinimum="yes"
        Maximum="$(Version)" IncludeMaximum="yes"
        Property="SAME_VERSION_FOUND" />
      <UpgradeVersion
        Minimum="$(Version)" IncludeMinimum="no"
        Property="DOWNGRADE_FOUND" />
    </Upgrade>

    <!-- Block reinstall of identical version -->
    <Launch Condition="NOT SAME_VERSION_FOUND"
            Message="PokeTeamDex $(Version) is already installed on this computer.&#13;&#10;To reinstall, please uninstall the current version first." />

    <!--
      Upgrade indication: when UPGRADE_FOUND is set the install directory is
      pre-filled from the registry (INSTALLFOLDER RegistrySearch above), giving
      the user a clear visual cue that an existing installation was detected.
      The ARPCOMMENTS property records version info in Windows Apps & Features.
    -->
    <SetProperty Id="ARPCOMMENTS"
      Value="Upgrading to $(Version)"
      Before="InstallInitialize"
      Sequence="execute"
      Condition="UPGRADE_FOUND" />

    <MediaTemplate EmbedCab="yes" />

    <!--
      WixUI_InstallDir: License → Install Directory (with Browse button) → Install → Finish.
    -->
    <ui:WixUI Id="WixUI_InstallDir" />
    <WixVariable Id="WixUILicenseRtf" Value="$(sys.SOURCEFILEDIR)license.rtf" />

    <!-- Required by WixUI_InstallDir to know which property holds the install path -->
    <Property Id="WIXUI_INSTALLDIR" Value="INSTALLFOLDER" />

    <!--
      Pre-fill install path from previous installation.
      ARPINSTALLLOCATION is set during install (see below) so Windows records it.
      On the next install/upgrade that registry value is read back as the default.
    -->
    <Property Id="INSTALLFOLDER">
      <RegistrySearch Id="PreviousInstallDir"
        Root="HKLM"
        Key="SOFTWARE\Microsoft\Windows\CurrentVersion\Uninstall\{E3A7F1B2-4C5D-4E6F-8A9B-0C1D2E3F4A5B}"
        Name="InstallLocation"
        Type="raw" />
    </Property>

    <!-- Tell Windows Add/Remove Programs where the app is installed.
         SetProperty is required because [INSTALLFOLDER] is a property reference
         and cannot be used directly in a Property element value (WIX1077). -->
    <SetProperty Id="ARPINSTALLLOCATION"
      Value="[INSTALLFOLDER]"
      Before="InstallValidate"
      Sequence="execute" />

    <!-- "Launch PokeTeamDex" checkbox on the Finish screen, ticked by default -->
    <Property Id="WIXUI_EXITDIALOGOPTIONALCHECKBOX" Value="1" />
    <Property Id="WIXUI_EXITDIALOGOPTIONALCHECKBOXTEXT" Value="Launch PokeTeamDex" />

    <!--
      Launch the app after the user clicks Finish.
      ExitDialog blocks the InstallUISequence until dismissed; scheduling
      LaunchApp After="ExitDialog" (see fragment below) fires only once
      the user clicks Finish. Type-34 custom action: Directory sets the
      working dir, ExeCommand is the quoted full path resolved at run time.
    -->
    <CustomAction Id="LaunchApp"
      Directory="INSTALLFOLDER"
      ExeCommand="&quot;[INSTALLFOLDER]poke_team_dex.exe&quot;"
      Return="asyncNoWait" />

    <!-- ── Single feature — all components always installed ───────────── -->

    <Feature Id="Complete"
             Title="PokeTeamDex"
             Level="1"
             AllowAdvertise="no"
             AllowAbsent="no">
      <ComponentGroupRef Id="ProductComponents" />
      <ComponentRef Id="StartMenuShortcutComp" />
      <ComponentRef Id="DesktopShortcutComp" />
    </Feature>
  </Package>

  <!-- ── Directory layout ─────────────────────────────────────────── -->

  <Fragment>
    <StandardDirectory Id="ProgramFiles64Folder">
      <Directory Id="INSTALLFOLDER" Name="PokeTeamDex" />
    </StandardDirectory>
    <StandardDirectory Id="ProgramMenuFolder">
      <Directory Id="ApplicationProgramsFolder" Name="PokeTeamDex" />
    </StandardDirectory>
    <StandardDirectory Id="DesktopFolder" />
  </Fragment>

  <!-- ── Shortcut components ──────────────────────────────────────── -->

  <Fragment>
    <Component Id="StartMenuShortcutComp" Directory="ApplicationProgramsFolder">
      <Shortcut Id="StartMenuShortcutId"
                Name="PokeTeamDex"
                Target="[INSTALLFOLDER]poke_team_dex.exe"
                WorkingDirectory="INSTALLFOLDER"
                Icon="AppIcon" />
      <RemoveFolder Id="CleanUpStartMenuFolder"
                    Directory="ApplicationProgramsFolder"
                    On="uninstall" />
      <RegistryValue Root="HKCU"
                     Key="Software\Asante\PokeTeamDex"
                     Name="StartMenu"
                     Type="integer"
                     Value="1"
                     KeyPath="yes" />
    </Component>

    <Component Id="DesktopShortcutComp" Directory="DesktopFolder">
      <Shortcut Id="DesktopShortcutId"
                Name="PokeTeamDex"
                Target="[INSTALLFOLDER]poke_team_dex.exe"
                WorkingDirectory="INSTALLFOLDER"
                Icon="AppIcon" />
      <RegistryValue Root="HKCU"
                     Key="Software\Asante\PokeTeamDex"
                     Name="Desktop"
                     Type="integer"
                     Value="1"
                     KeyPath="yes" />
    </Component>

    <Icon Id="AppIcon" SourceFile="$(IconFile)" />
  </Fragment>

  <!-- ── Install sequence ─────────────────────────────────────────── -->

  <Fragment>
    <InstallExecuteSequence>
      <RemoveExistingProducts After="InstallInitialize" />
    </InstallExecuteSequence>
    <InstallUISequence>
      <!--
        ExitDialog blocks the UISequence until Finish is clicked.
        WixShellExec After="ExitDialog" therefore only fires after the user
        dismisses the dialog, respecting the checkbox state.
        NOT REMOVE prevents launch during uninstall.
      -->
      <Custom Action="LaunchApp" After="ExitDialog" Condition="WIXUI_EXITDIALOGOPTIONALCHECKBOX = 1 AND NOT REMOVE" />
    </InstallUISequence>
  </Fragment>

</Wix>
