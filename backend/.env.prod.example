# Copy this to .env.prod and fill in real values.
# .env.prod is gitignored — never commit it.

# Supabase connection string (Session mode pooler, port 5432)
# Supabase dashboard → Settings → Database → Connection string → Session mode
# Change postgresql:// to postgresql+asyncpg://
DATABASE_URL=postgresql+asyncpg://postgres.xxxx:your-password@aws-0-eu-west-2.pooler.supabase.com:5432/postgres

# JWT — generate with: openssl rand -hex 64
SECRET_KEY=change-me-to-a-long-random-string
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=43200

# Update notifications
APP_VERSION=1.0.0
# Must match the NOTIFY_UPDATE_SECRET GitHub Secret exactly
NOTIFY_UPDATE_SECRET=change-me-openssl-rand-hex-32
# Firebase service account JSON (single-line, from Firebase Console → Service Accounts)
FIREBASE_SERVICE_ACCOUNT_JSON={}
