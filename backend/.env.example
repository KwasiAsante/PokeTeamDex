DATABASE_URL=postgresql+asyncpg://user:password@host:5432/poketeamdex
# Set to true locally to enable /docs Swagger UI — never true in production
DEBUG=false
SECRET_KEY=change-me-to-a-long-random-string
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=43200

# Set to current release version (updated automatically by CI via /admin/notify-update)
APP_VERSION=1.0.0

# Shared secret between GitHub Actions and this backend for /admin/notify-update
# Generate with: openssl rand -hex 32
NOTIFY_UPDATE_SECRET=a44d000c7b56495a079fd33fcd3338201673a409d261a762f391cdfd62a64eaf

# Firebase service account JSON (single-line, stringified)
# Leave as {} to disable FCM push notifications (update polling still works)
FIREBASE_SERVICE_ACCOUNT_JSON={}

# Loki URL for structured log push (Docker Compose internal default)
# Change to your Loki instance URL if not co-located on the same Docker network
LOKI_URL=http://loki:3100
