DATABASE_URL=postgresql+asyncpg://user:password@host:5432/poketeamdex
# Set to true locally to enable /docs Swagger UI — never true in production
DEBUG=false
SECRET_KEY=change-me-to-a-long-random-string
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=43200

# Set to current release version (updated automatically by CI via /admin/notify-update)
APP_VERSION=1.0.0

# Shared secret between GitHub Actions and this backend for /admin/notify-update
# Generate with: openssl rand -hex 32
NOTIFY_UPDATE_SECRET=a44d000c7b56495a079fd33fcd3338201673a409d261a762f391cdfd62a64eaf

# Firebase service account JSON (single-line, stringified)
# Leave as {} to disable FCM push notifications (update polling still works)
FIREBASE_SERVICE_ACCOUNT_JSON={}

# Structured logging — UtilityBillsServer endpoint that receives log lines
# Leave as default unless you run your own instance
LOGS_API_BASE_URL=https://kwasi-utilitybills.duckdns.org
# Service account credentials for UtilityBillsServer — backend registers/logins
# on startup and forwards log lines with Authorization: Bearer <token>.
# Leave empty to skip auth (only works if UtilityBillsServer has no users).
LOGS_API_EMAIL=
LOGS_API_PASSWORD=
